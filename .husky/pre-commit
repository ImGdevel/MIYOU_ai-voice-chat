#!/usr/bin/env sh

set -e

STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$' || true)
STAGED_KOTLIN_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(kt|kts)$' || true)

if [ -z "$STAGED_JAVA_FILES" ] && [ -z "$STAGED_KOTLIN_FILES" ]; then
  echo "포매팅할 Java/Kotlin 파일이 없습니다."
  exit 0
fi

if [ -n "$STAGED_JAVA_FILES" ]; then
  echo "staged Java 파일 Spotless 적용 시작..."
  ./gradlew spotlessApply

  for FILE in $STAGED_JAVA_FILES; do
    if [ -f "$FILE" ]; then
      git add "$FILE"
    fi
  done

  echo "staged Java 파일 Spotless 적용 완료"
fi

if [ -n "$STAGED_KOTLIN_FILES" ]; then
  echo "staged Kotlin 파일 ktlintFormat 적용 시작..."
  ./gradlew ktlintFormat

  for FILE in $STAGED_KOTLIN_FILES; do
    if [ -f "$FILE" ]; then
      git add "$FILE"
    fi
  done

  echo "staged Kotlin 파일 ktlintFormat 적용 완료"
fi
