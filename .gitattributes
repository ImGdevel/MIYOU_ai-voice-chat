* text=auto eol=lf

# Windows launchers must keep CRLF.
*.bat text eol=crlf

# Binary artifacts must not be normalized.
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary

# Force UTF-8 and LF for project text files.
/gradlew text eol=lf
.gitattributes text eol=lf working-tree-encoding=UTF-8
.gitignore text eol=lf working-tree-encoding=UTF-8
*.md text eol=lf working-tree-encoding=UTF-8
*.MD text eol=lf working-tree-encoding=UTF-8
*.java text eol=lf working-tree-encoding=UTF-8
*.kt text eol=lf working-tree-encoding=UTF-8
*.kts text eol=lf working-tree-encoding=UTF-8
*.groovy text eol=lf working-tree-encoding=UTF-8
*.gradle text eol=lf working-tree-encoding=UTF-8
*.properties text eol=lf working-tree-encoding=UTF-8
*.yml text eol=lf working-tree-encoding=UTF-8
*.yaml text eol=lf working-tree-encoding=UTF-8
*.xml text eol=lf working-tree-encoding=UTF-8
*.json text eol=lf working-tree-encoding=UTF-8
*.sh text eol=lf working-tree-encoding=UTF-8
.editorconfig text eol=lf working-tree-encoding=UTF-8
.husky/* text eol=lf
